# Gogetlinks Task Parser - Configuration Template
# Скопируйте этот файл в config.ini и заполните своими данными
# ВАЖНО: chmod 600 config.ini для защиты credentials

[gogetlinks]
# Учётные данные для входа на gogetlinks.net
username = user@example.com
password = your_password_here

[anticaptcha]
# API ключ от anti-captcha.com (https://anti-captcha.com/)
# Убедитесь что баланс > $5 для стабильной работы
api_key = your_api_key_here

[database]
# Настройки подключения к MySQL
host = localhost
port = 3306
database = gogetlinks
user = gogetlinks_parser
password = your_db_password

[telegram]
# Telegram-уведомления о новых задачах
# Создайте бота через @BotFather и получите токен
# Добавьте бота в групповой чат и получите chat_id
enabled = false
bot_token = 123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
chat_id = -100123456789

[output]
# Выводить задачи в консоль (true для тестирования, false для cron)
# print_tasks = false
print_to_console = true

[logging]
# Уровень логирования: DEBUG, INFO, WARNING, ERROR, CRITICAL
log_level = INFO
# Путь к файлу логов (убедитесь что папка существует)
log_file = gogetlinks_parser.log
